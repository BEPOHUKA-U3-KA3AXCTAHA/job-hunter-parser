[importlinter]
root_packages =
    app
include_external_packages = True

# Rule 1 — application layer doesn't import infra.
# services/, models/, ports/ inside any module may NOT touch app.infra.* OR
# any third-party persistence/HTTP/automation library. Adapters and
# entrypoints are the only legal homes.
[importlinter:contract:1-services-no-infra]
name = Rule 1 — services/models/ports do not import infra
type = forbidden
# Only fail on DIRECT import statements. Transitive chains through a
# module's own __init__.py (which legitimately re-exports composition-
# root factories that lazy-load infra) don't count as a violation.
allow_indirect_imports = True
source_modules =
    app.modules.applies.services
    app.modules.applies.models
    app.modules.applies.ports
    app.modules.companies.services
    app.modules.companies.models
    app.modules.companies.ports
    app.modules.people.services
    app.modules.people.models
    app.modules.people.ports
    app.modules.users.services
    app.modules.users.models
    app.modules.users.ports
    app.modules.automation.services
    app.modules.automation.models
forbidden_modules =
    app.infra
    sqlalchemy
    asyncpg
    httpx
    requests
    playwright
    selenium
    boto3
    boto

# Rule 4 — cross-module imports go through __init__.py only.
# Concretely: never reach into another module's adapters/, services/,
# models/, or ports/ subpackages from the outside. Only the top-level
# package (which re-exports the public API) is fair game.
# Rule 4 — cross-module imports go through __init__.py only.
# Enforced by scripts/lint_arch.py (raw-source AST check). import-linter's
# graph analysis can't distinguish a direct `from app.modules.B.adapters
# import X` from a transitive load through B's own __init__.py, so this
# rule is checked at the source-statement level.

# Rule 5 — infra/ never imports from modules/ or entrypoints/.
[importlinter:contract:5-infra-no-uplift]
name = Rule 5 — infra does not import from modules or entrypoints
type = forbidden
source_modules =
    app.infra
forbidden_modules =
    app.modules
    app.entrypoints
