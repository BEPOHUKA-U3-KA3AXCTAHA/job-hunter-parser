# ========== LLM APIs ==========
# Claude API key for generating personalized outreach messages
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI as fallback
OPENAI_API_KEY=sk-...

# ========== Contact Enrichment ==========
# Apollo.io API key (free tier: 10k contacts/mo)
# https://apollo.io
APOLLO_API_KEY=

# Hunter.io API key (free tier: 25 searches/mo)
# https://hunter.io
HUNTER_API_KEY=

# ========== Database ==========
# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter

# ========== Scrapers ==========
# LinkedIn (optional, for scraper)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ========== Google Sheets Export (optional) ==========
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google_sa.json
GOOGLE_SHEETS_ID=

# ========== Application ==========
LOG_LEVEL=INFO
ENVIRONMENT=development
