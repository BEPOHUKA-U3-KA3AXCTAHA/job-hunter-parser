{
  "manifest_version": 2,
  "name": "JHP Easy Apply",
  "version": "0.2.0",
  "description": "Auto-apply jobs from Job Hunter Parser queue. Real Firefox session means LinkedIn / Cloudflare Turnstile / etc. see no automation signals.",
  "browser_specific_settings": {
    "gecko": {
      "id": "jhp-easy-apply@bro.local",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "<all_urls>",
    "http://localhost:8765/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "external_fill.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "JHP Easy Apply",
    "default_popup": "popup.html"
  }
}
